# 代码功能：演示列表的复制
my_foods = ['pizza', 'falafel', 'carrot cake']
friend_food = my_foods[:]

print("My favorite food are:")
print(my_foods)

print("\nMy friend's favorite foods are:")
print(friend_food)

# 各自添加
my_foods = ['pizza', 'falafel', 'carrot cake']
friend_food = my_foods[:]

my_foods.append('canoli')
friend_food.append('ice cream')

print("My favorite food are:")
print(my_foods)

print("\nMy friend's favorite foods are:")
print(friend_food)

